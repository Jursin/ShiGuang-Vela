<template>
  <div class="page">
    <div class="day-list">
      <input class="day-btn" type="button" value="周一" onclick="pickMon" />
      <input class="day-btn" type="button" value="周二" onclick="pickTue" />
      <input class="day-btn" type="button" value="周三" onclick="pickWed" />
      <input class="day-btn" type="button" value="周四" onclick="pickThu" />
      <input class="day-btn" type="button" value="周五" onclick="pickFri" />
      <input class="day-btn" type="button" value="周六" onclick="pickSat" />
      <input class="day-btn" type="button" value="周日" onclick="pickSun" />
    </div>

    <input class="back-btn" type="button" value="返回" onclick="back" />
  </div>
</template>

<script>
import router from "@system.router"

export default {
  pickMon() {
    this.pick(1)
  },

  pickTue() {
    this.pick(2)
  },

  pickWed() {
    this.pick(3)
  },

  pickThu() {
    this.pick(4)
  },

  pickFri() {
    this.pick(5)
  },

  pickSat() {
    this.pick(6)
  },

  pickSun() {
    this.pick(7)
  },

  pick(day) {
    router.replace({
      uri: "/pages/index",
      params: {
        fromPicker: true,
        selectedDayParam: String(day)
      }
    })
  },

  back() {
    router.back()
  }
}
</script>

