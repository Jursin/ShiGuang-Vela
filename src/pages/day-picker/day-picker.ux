.page {
  flex-direction: column;
  width: 100%;
  height: 100%;
  padding: 14px;
  background-color: #000000;
  align-items: center;
}

.day-list {
  flex-direction: column;
  align-items: center;
  margin-top: 14px;
  width: 100%;
}

.day-btn {
  width: 58%;
  height: 42px;
  margin-bottom: 10px;
  border-radius: 20px;
  border-width: 2px;
  border-color: #3b3b3b;
  background-color: #0c0c0c;
  color: #ffffff;
  font-size: 24px;
  text-align: center;
  padding-left: 8px;
  padding-right: 8px;
  padding-top: 8px;
  padding-bottom: 8px;
}

.back-btn {
  width: 58%;
  height: 42px;
  margin-top: 6px;
  border-radius: 20px;
  border-width: 2px;
  border-color: #3b3b3b;
  background-color: #111111;
  color: #ffffff;
  font-size: 24px;
  text-align: center;
  padding-left: 8px;
  padding-right: 8px;
  padding-top: 8px;
  padding-bottom: 8px;
}
</style>
