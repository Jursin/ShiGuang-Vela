  flex-direction: column;
  width: 100%;
  height: 100%;
  padding: 14px;
  background-color: #000000;
  align-items: center;
}

.title {
  color: #ffffff;
  font-size: 28px;
  font-weight: 700;
}

.menu-btn {
  width: 84%;
  height: 52px;
  margin-top: 14px;
  border-radius: 20px;
  border-width: 2px;
  border-color: #3b3b3b;
  background-color: #0c0c0c;
  color: #ffffff;
  font-size: 24px;
  font-weight: 700;
  text-align: center;
  padding-left: 10px;
  padding-right: 10px;
  padding-top: 10px;
  padding-bottom: 10px;
}

.warn-btn {
  width: 84%;
  height: 52px;
  margin-top: 12px;
  border-radius: 20px;
  border-width: 2px;
  border-color: #4a2b2b;
  background-color: #130909;
  color: #ffbcbc;
  font-size: 24px;
  font-weight: 700;
  text-align: center;
  padding-left: 10px;
  padding-right: 10px;
  padding-top: 10px;
  padding-bottom: 10px;
}

.btn {
  width: 84%;
  height: 46px;
  margin-top: 12px;
  border-radius: 20px;
  border-width: 2px;
  border-color: #3b3b3b;
  background-color: #111111;
  color: #ffffff;
  font-size: 24px;
  font-weight: 700;
  text-align: center;
  padding-left: 10px;
  padding-right: 10px;
  padding-top: 10px;
  padding-bottom: 10px;
}
</style>
