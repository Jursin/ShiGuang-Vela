  width: 100%;
  margin-top: 12px;
  height: 44px;
  align-items: center;
  justify-content: center;
}

.picker-label {
  width: 30px;
  color: #ffffff;
  font-size: 24px;
}

.op-btn {
  width: 44px;
  height: 44px;
  margin-left: 8px;
  border-radius: 10px;
  border-width: 2px;
  border-color: #3b3b3b;
  background-color: #0c0c0c;
  color: #ffffff;
  font-size: 28px;
  font-weight: 700;
  text-align: center;
  padding-left: 10px;
  padding-right: 10px;
  padding-top: 10px;
  padding-bottom: 10px;
}

.picker-value {
  width: 82px;
  margin-left: 8px;
  text-align: center;
  color: #ffffff;
  font-size: 24px;
}

.save-btn {
  width: 84%;
  height: 46px;
  margin-top: 16px;
  border-radius: 20px;
  border-width: 2px;
  border-color: #3b3b3b;
  background-color: #111111;
  color: #ffffff;
  font-size: 24px;
  font-weight: 700;
  text-align: center;
  padding-left: 10px;
  padding-right: 10px;
  padding-top: 10px;
  padding-bottom: 10px;
}

.back-btn {
  width: 84%;
  height: 46px;
  margin-top: 10px;
  border-radius: 20px;
  border-width: 2px;
  border-color: #3b3b3b;
  background-color: #111111;
  color: #ffffff;
  font-size: 24px;
  font-weight: 700;
  text-align: center;
  padding-left: 10px;
  padding-right: 10px;
  padding-top: 10px;
  padding-bottom: 10px;
}
</style>
