{
  "name": "schedule-vela",
  "version": "1.0.0",
  "description": "适用于 Vela 设备的课程表快应用",
  "engines": {
    "node": ">=8.10"
  },
  "scripts": {
    "start": "aiot start --watch",
    "build": "aiot build",
    "release": "aiot release",
    "lint": "eslint --format codeframe --fix --ext .ux,.js src/"
  },
  "lint-staged": {
    "*.{ux,js}": [
      "prettier --write",
      "eslint --format codeframe --fix",
      "git add"
    ],
    "*.{less,css}": [
      "prettier --write",
      "stylelint --fix --custom-syntax postcss-less",
      "git add"
    ]
  },
  "devDependencies": {
    "@aiot-toolkit/jsc": "^1.0.8",
    "aiot-toolkit": "^2.0.5"
  }
}